@startuml
title Recherche avancee d'ouvrages

actor "Client" as C
participant "OuvragesController" as CTL
participant "OuvrageRepository" as OR
participant "PostgreSQL" as DB

C -> CTL : GET /api/ouvrages?titre=X&auteur=Y&isbn=Z&code_barre=B&disponible=true
activate CTL
CTL -> OR : Rechercher(filtres)
activate OR
note right of OR : Construction dynamique\nde la requete SQL\nselon les filtres fournis
OR -> DB : SELECT ouvrages+livres+auteurs UNION ALL ouvrages+revues\nWHERE <filtres> ORDER BY titre
activate DB
DB --> OR : []OuvrageResultat
deactivate DB
OR --> CTL : []OuvrageResultat, nil
deactivate OR
alt Resultats trouves
CTL --> C : 200 [{id, titre, type, auteur, isbn, date_parution, caution, disponibles}]
else Aucun resultat
CTL --> C : 204 No Content
end
deactivate CTL
@enduml
