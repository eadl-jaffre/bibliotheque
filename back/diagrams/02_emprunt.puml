@startuml
title Emprunt d'un exemplaire

actor "Client (utilisateur connecte)" as C
participant "EmpruntController" as CTL
participant "EmpruntRepository" as ER
participant "PostgreSQL" as DB

== Etape 1 - Verification ==
C -> CTL : GET /api/emprunts/verifier?code_barre=X&utilisateur_id=Y
activate CTL
CTL -> ER : Verifier(codeBarre, utilisateurId)
activate ER
ER -> DB : SELECT exemplaire + verifications metier
activate DB
alt Toutes les verifications passent
DB --> ER : PreviewEmprunt
deactivate DB
ER --> CTL : PreviewEmprunt, nil
deactivate ER
CTL --> C : 200 {titre, auteur, caution, date_fin_prevue}
else Exemplaire deja emprunte
CTL --> C : 400 Cet exemplaire est deja emprunte
else Solde caution insuffisant
CTL --> C : 400 Solde de caution insuffisant
else Limite de 3 emprunts atteinte
CTL --> C : 400 Limite de 3 emprunts simultanees atteinte
end
deactivate CTL

== Etape 2 - Enregistrement ==
C -> CTL : POST /api/emprunts\n{code_barre, utilisateur_id}
activate CTL
CTL -> ER : Emprunter(codeBarre, utilisateurId)
activate ER
ER -> DB : BEGIN TRANSACTION
activate DB
ER -> DB : UPDATE exemplaires SET est_emprunte=true, emprunteur_id, dates
ER -> DB : UPDATE utilisateurs SET solde_caution -= caution
ER -> DB : COMMIT
deactivate DB
ER --> CTL : nil
deactivate ER
CTL --> C : 200 {message: Emprunt enregistre avec succes}
deactivate CTL
@enduml
