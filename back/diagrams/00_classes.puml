namespace test {
}
namespace uml {
    interface "Diagram"  {
        + WriteFile(path string) error

    }
    class "SequenceDiagram" << (S,Aquamarine) >> {
        - title string
        - lines []string

        - add(l string) *SequenceDiagram

        + Participant(alias string, label string) *SequenceDiagram
        + Actor(alias string, label string) *SequenceDiagram
        + Arrow(from string, to string, msg string) *SequenceDiagram
        + DashedArrow(from string, to string, msg string) *SequenceDiagram
        + Activate(alias string) *SequenceDiagram
        + Deactivate(alias string) *SequenceDiagram
        + AltStart(condition string) *SequenceDiagram
        + Else(condition string) *SequenceDiagram
        + End() *SequenceDiagram
        + GroupStart(label string) *SequenceDiagram
        + Note(side string, alias string, msg string) *SequenceDiagram
        + Separator(label string) *SequenceDiagram
        + Blank() *SequenceDiagram
        + String() string
        + WriteTo(w io.Writer) error
        + WriteFile(path string) error

    }
    class "UseCaseDiagram" << (S,Aquamarine) >> {
        - title string
        - lines []string

        - add(l string) *UseCaseDiagram

        + Direction(dir string) *UseCaseDiagram
        + Actor(alias string, label string) *UseCaseDiagram
        + ActorInherits(child string, parent string) *UseCaseDiagram
        + UseCase(alias string, label string) *UseCaseDiagram
        + RectangleStart(label string) *UseCaseDiagram
        + RectangleEnd() *UseCaseDiagram
        + Association(from string, to string) *UseCaseDiagram
        + Include(from string, to string) *UseCaseDiagram
        + Extend(from string, to string) *UseCaseDiagram
        + Blank() *UseCaseDiagram
        + String() string
        + WriteTo(w io.Writer) error
        + WriteFile(path string) error

    }
}
"builder.UtilisateurBuilder" *-- "builder.EnseignantBuilder"
"builder.UtilisateurBuilder" *-- "builder.EtudiantBuilder"
"models.Utilisateur" *-- "models.Enseignant"
"models.Utilisateur" *-- "models.Etudiant"
"models.Ouvrage" *-- "models.Livre"
"models.Ouvrage" *-- "models.Revue"

"fabrique.FabriqueOuvrage" <|-- "fabrique.FabriqueLivre"
"fabrique.FabriqueOuvrage" <|-- "fabrique.FabriqueRevue"
"models.IOuvrage" <|-- "models.Ouvrage"
"uml.Diagram" <|-- "uml.SequenceDiagram"
"uml.Diagram" <|-- "uml.UseCaseDiagram"


@enduml
