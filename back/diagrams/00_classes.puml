    class "EmpruntEnRetardItem" << (S,Aquamarine) >> {
        + Id int
        + CodeBarre string
        + Titre string
        + DateFin string
        + Nom string
        + Prenom string
        + NumeroTelephone string

    }
    class "EmpruntItem" << (S,Aquamarine) >> {
        + Id int
        + CodeBarre string
        + Titre string
        + DateDebut string
        + DateFin string
        + EnRetard bool

    }
    class "EmpruntRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + Verifier(utilisateurId int, codeBarre string) (*PreviewEmprunt, error)
        + GetEmprunts(utilisateurId int) ([]*EmpruntItem, error)
        + GetEmpruntsEnRetard() ([]*EmpruntEnRetardItem, error)
        + Emprunter(utilisateurId int, codeBarre string) error

    }
    class "EnseignantRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + FindAll() ([]*models.Enseignant, error)
        + FindByID(id int) (*models.Enseignant, error)
        + FindByDepartement(departementID int) ([]*models.Enseignant, error)
        + Create(en *models.Enseignant) (int, error)
        + Update(en *models.Enseignant) error
        + Delete(id int) error

    }
    class "EtudiantRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + FindAll() ([]*models.Etudiant, error)
        + FindByID(id int) (*models.Etudiant, error)
        + Create(et *models.Etudiant) (int, error)
        + Update(et *models.Etudiant) error
        + Delete(id int) error

    }
    class "ExemplaireRepository" << (S,Aquamarine) >> {
