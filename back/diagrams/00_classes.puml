        + RechercherUtilisateurs(nom string, prenom string, codePostal string, numeroTelephone string) ([]*UtilisateurResume, error)
        + LoginExists(login string) (bool, error)

    }
    class "UtilisateurResume" << (S,Aquamarine) >> {
        + Id int
        + Nom string
        + Prenom string
        + NumeroTelephone string
