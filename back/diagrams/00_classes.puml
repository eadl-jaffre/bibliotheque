@startuml
namespace back {
}
namespace builder {
    class "EnseignantBuilder" << (S,Aquamarine) >> {
        - departement *models.DepartementEcole

        + WithNom(nom string) *EnseignantBuilder
        + WithPrenom(prenom string) *EnseignantBuilder
        + WithLogin(login string) *EnseignantBuilder
        + WithMotDePasse(mdp string) *EnseignantBuilder
        + WithEmail(email string) *EnseignantBuilder
        + WithNumeroTelephone(tel string) *EnseignantBuilder
        + WithSoldeCaution(solde float64) *EnseignantBuilder
        + WithDateDeNaissance(date time.Time) *EnseignantBuilder
        + WithDepartement(dept *models.DepartementEcole) *EnseignantBuilder
        + Build() *models.Enseignant

    }
    class "EtudiantBuilder" << (S,Aquamarine) >> {
        - anneeEtude string

        + WithNom(nom string) *EtudiantBuilder
        + WithPrenom(prenom string) *EtudiantBuilder
        + WithLogin(login string) *EtudiantBuilder
        + WithMotDePasse(mdp string) *EtudiantBuilder
        + WithEmail(email string) *EtudiantBuilder
        + WithNumeroTelephone(tel string) *EtudiantBuilder
        + WithSoldeCaution(solde float64) *EtudiantBuilder
        + WithDateDeNaissance(date time.Time) *EtudiantBuilder
        + WithAnneeEtude(annee string) *EtudiantBuilder
        + Build() *models.Etudiant

    }
    class "UtilisateurBuilder" << (S,Aquamarine) >> {
        - u models.Utilisateur

        + WithNom(nom string) *UtilisateurBuilder
        + WithPrenom(prenom string) *UtilisateurBuilder
        + WithLogin(login string) *UtilisateurBuilder
        + WithMotDePasse(mdp string) *UtilisateurBuilder
        + WithEmail(email string) *UtilisateurBuilder
        + WithNumeroTelephone(tel string) *UtilisateurBuilder
        + WithSoldeCaution(solde float64) *UtilisateurBuilder
        + WithDateDeNaissance(date time.Time) *UtilisateurBuilder
        + Build() *models.Utilisateur

    }
}
namespace cmd {
    namespace gen-uml {
    }
}
namespace controllers {
    class "AccueilStats" << (S,Aquamarine) >> {
        + NbLivres int
        + NbRevues int
        + NbExemplairesDisponibles int
        + NbUtilisateurs int

    }
    class "ConnexionRequest" << (S,Aquamarine) >> {
        + Login string
        + MotDePasse string

    }
    class "ConnexionResponse" << (S,Aquamarine) >> {
        + Id int
        + Nom string
        + Prenom string
        + Role string
        + Message string

    }
    class "CreerLivreRequest" << (S,Aquamarine) >> {
        + Titre string
        + Caution float64
        + Isbn string
        + AuteurId int
        + AuteurNom string
        + AuteurPrenom string
        + EmplacementId int

    }
    class "CreerRevueRequest" << (S,Aquamarine) >> {
        + Titre string
        + Caution float64
        + Numero int
        + DateParution string
        + EmplacementId int

    }
    class "CreerUtilisateurRequest" << (S,Aquamarine) >> {
        + Nom string
        + Prenom string
        + NumeroTelephone string
        + DateNaissance string
        + Email string
        + Statut string
        + AnneeEtude string
        + DepartementId int
        + NumeroRue string
        + NomRue string
        + CodePostal string
        + Ville string

    }
    class "CreerUtilisateurResponse" << (S,Aquamarine) >> {
        + Login string
        + MotDePasse string
        + Message string

    }
    class "EmpruntRequest" << (S,Aquamarine) >> {
        + UtilisateurId int
        + CodeBarre string

    }
    class "ExemplaireResume" << (S,Aquamarine) >> {
        + Id int
        + CodeBarre string

    }
}
namespace db {
    class "Config" << (S,Aquamarine) >> {
        + Host string
        + Port int
        + User string
        + Password string
        + DBName string
        + SSLMode string

    }
    class "DBO" << (S,Aquamarine) >> {
        - conn *sql.DB

        + Close() error
        + QueryRows(query string, args ...any) (*sql.Rows, error)
        + QueryRow(query string, args ...any) *sql.Row
        + Exec(query string, args ...any) (int64, error)
        + ExecReturning(query string, args ...any) *sql.Row
        + BeginTx() (*TxDBO, error)
        + WithTx(fn <font color=blue>func</font>(*TxDBO) error) error
        + SeedIfEmpty(scriptPath string) error

    }
    class "TxDBO" << (S,Aquamarine) >> {
        - tx *sql.Tx

        + QueryRows(query string, args ...any) (*sql.Rows, error)
        + QueryRow(query string, args ...any) *sql.Row
        + Exec(query string, args ...any) (int64, error)
        + ExecReturning(query string, args ...any) *sql.Row
        + Commit() error
        + Rollback() error

    }
}
namespace fabrique {
    class "FabriqueLivre" << (S,Aquamarine) >> {
        + Titre string
        + Caution float64
        + Isbn string
        + Auteur *models.Auteur

        + CreerOuvrage() models.IOuvrage

    }
    interface "FabriqueOuvrage"  {
        + CreerOuvrage() models.IOuvrage

    }
    class "FabriqueRevue" << (S,Aquamarine) >> {
        + Titre string
        + Caution float64
        + Numero int
        + DateParution time.Time

        + CreerOuvrage() models.IOuvrage

    }
}
namespace models {
    class "Auteur" << (S,Aquamarine) >> {
        + Id int
        + Nom string
        + Prenom string

    }
    class "Bibliothecaire" << (S,Aquamarine) >> {
        + Id int
        + Nom string
        + Prenom string
        + Login string
        + MotDePasse string

    }
    class "DepartementEcole" << (S,Aquamarine) >> {
        + Id int
        + Nom string

    }
    class "Enseignant" << (S,Aquamarine) >> {
        + DepartementId int
        + Departement *DepartementEcole

    }
    class "Etudiant" << (S,Aquamarine) >> {
        + AnneeEtude string

    }
    class "Exemplaire" << (S,Aquamarine) >> {
        + Id int
        + EstEmprunte bool
        + DateDebutEmprunt time.Time
        + DateFinEmprunt time.Time
        + DelaiEmpruntJours int
        + CodeBarre string
        + EmprunteurId int
        + Emprunteur *Utilisateur

    }
    interface "IOuvrage"  {
        + GetId() int
        + GetTitre() string
        + GetCaution() float64

    }
    class "Livre" << (S,Aquamarine) >> {
        + AuteurId int
        + Auteur *Auteur
        + Isbn string

    }
    class "Ouvrage" << (S,Aquamarine) >> {
        + Id int
        + Caution float64
        + Titre string
        + Exemplaires int

        + GetId() int
        + GetTitre() string
        + GetCaution() float64

    }
    class "Revue" << (S,Aquamarine) >> {
        + Numero int
        + DateParution time.Time

    }
    class "Utilisateur" << (S,Aquamarine) >> {
        + Id int
        + Nom string
        + Prenom string
        + NumeroTelephone string
        + SoldeCaution float64
        + Login string
        + MotDePasse string
        + DateDeNaissance time.Time
        + Email string
        + AdresseId *int
        + Emprunts []*Exemplaire

    }
}
namespace repositories {
    class "AuteurRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + FindAll() ([]*models.Auteur, error)
        + FindByID(id int) (*models.Auteur, error)
        + Create(a *models.Auteur) (int, error)
        + Update(a *models.Auteur) error
        + Delete(id int) error

    }
    class "BibliothécaireRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + FindAll() ([]*models.Bibliothecaire, error)
        + FindByID(id int) (*models.Bibliothecaire, error)
        + FindByLogin(login string) (*models.Bibliothecaire, error)
        + Create(b *models.Bibliothecaire) (int, error)
        + Update(b *models.Bibliothecaire) error
        + Delete(id int) error

    }
    class "DepartementEcoleRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

        + FindAll() ([]*models.DepartementEcole, error)
        + FindByID(id int) (*models.DepartementEcole, error)
        + Create(d *models.DepartementEcole) (int, error)
        + Update(d *models.DepartementEcole) error
        + Delete(id int) error

    }
    class "EmplacementRepository" << (S,Aquamarine) >> {
        - dbo *db.DBO

