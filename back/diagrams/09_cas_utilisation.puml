@startuml
title Diagramme de cas d'utilisation - Bibliotheque

left to right direction

actor "Bibliothecaire" as BIB
actor "Utilisateur" as UTI
actor "Etudiant" as ETU
actor "Enseignant" as ENS

UTI <|-- ETU
UTI <|-- ENS

rectangle "Gestion bibliotheque" {
usecase "connexion" as UC_CO
usecase "creer_utilisateur" as UC_CU
usecase "trouver_un_utilisateur" as UC_TU
usecase "lister_les_retards" as UC_LR
usecase "enregistrer_ouvrage" as UC_EO
usecase "rechercher_ouvrage" as UC_RO
usecase "lister_emprunts_utilisateur" as UC_LEU
usecase "lister_ses_emprunts" as UC_LSE
usecase "emprunter_un_ouvrage" as UC_EU
}

BIB --> UC_CU
BIB --> UC_TU
BIB --> UC_LR
BIB --> UC_EO
BIB --> UC_RO
BIB --> UC_LEU

UTI --> UC_RO
UTI --> UC_LSE
UTI --> UC_EU

UC_CU ..> UC_CO : <<include>>
UC_TU ..> UC_CO : <<include>>
UC_EO ..> UC_CO : <<include>>
UC_LEU ..> UC_TU : <<include>>
UC_LSE ..> UC_CO : <<include>>
UC_EU ..> UC_CO : <<include>>
@enduml
